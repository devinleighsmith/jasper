{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "CsoKeycloak": {
    "Authority": "https://common-sso.justice.gov.bc.ca/auth/realms/Judiciary",
    "Audience": "JASPER-Dev",
    "ClientId": "CSO-JASPER-Dev",
    "WriteRole": "cso-order-write",
    "ValidateIssuer": true,
    "RequireHttpsMetadata": true
  },
  "CsoClientKeycloak": {
    "Authority": "https://common-sso.justice.gov.bc.ca/auth/realms/Judiciary",
    "Audience": "CSO",
    "ClientId": "JASPER-CSO-Mock",
    "RefreshSkewSeconds": 60
  },
  "DARS": {
    "LogsheetUrl": "https://test.jag.gov.bc.ca/darspc/",
    "URL": "https://wsgw.test.jag.gov.bc.ca/courts/DARS"
  },
  "SignalR": {
    "PostgresChannel": "signalr",
    "PostgresMaxPayloadBytes": 7000,
    "PostgresOutboxPollSeconds": 10,
    "PostgresOutboxBatchSize": 100,
    "PostgresOutboxRetentionMinutes": 1440,
    "PostgresOutboxMinAgeSeconds": 5,
    "KeepAliveIntervalSeconds": 30,
    "ClientTimeoutIntervalSeconds": 90,
    "MaximumReceiveMessageSizeBytes": 65536
  },
  "PublicCorsDomain": "https://localhost:8080"
}
